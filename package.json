{
  "name": "time",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:seed": "tsx scripts/seed-knowledge.ts",
    "db:embeddings": "tsx scripts/generate-embeddings.ts",
    "sync:ide": "node .aios-core/infrastructure/scripts/ide-sync/index.js sync",
    "sync:ide:check": "node .aios-core/infrastructure/scripts/ide-sync/index.js validate --strict",
    "sync:skills:codex": "node .aios-core/infrastructure/scripts/codex-skills-sync/index.js",
    "sync:skills:codex:global": "node .aios-core/infrastructure/scripts/codex-skills-sync/index.js --global",
    "validate:structure": "node .aios-core/infrastructure/scripts/validate-paths.js",
    "validate:agents": "node .aios-core/infrastructure/scripts/validate-agents.js",
    "validate:codex-integration": "node .aios-core/infrastructure/scripts/validate-codex-integration.js",
    "aios": "node scripts/aios-cli.cjs",
    "perf:build": "npm run build:analyze",
    "perf:audit": "npm run lint && npm run typecheck && npm run build",
    "netlify:build": "netlify build",
    "netlify:deploy": "netlify deploy --prod",
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/clean-dev.ps1",
    "dev:clean": "npm run clean && npm run dev"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/openai": "^3.0.30",
    "@ai-sdk/react": "^3.0.99",
    "@dicebear/collection": "^9.3.2",
    "@dicebear/core": "^9.3.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "ai": "^6.0.97",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.4",
    "geist": "^1.7.0",
    "lucide-react": "^0.575.0",
    "mammoth": "^1.11.0",
    "next": "^15.2.8",
    "next-themes": "^0.4.6",
    "openai": "^6.25.0",
    "pdf-parse": "^2.4.5",
    "postcss": "^8.5.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@netlify/plugin-nextjs": "^5.15.8",
    "@next/bundle-analyzer": "^16.1.6",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "15.1.0",
    "pg": "^8.18.0",
    "shadcn": "^3.8.5",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
